{
  "manifest_version": 3,
  "name": "Search Changer",
  "version": "1.0.1",
  "description": "Меняет поисковую систему по умолчанию",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "*://www.google.com/*",
    "*://www.bing.com/*",
    "*://duckduckgo.com/*",
    "*://yandex.ru/*"
  ],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "Search Changer"
  },
  "chrome_url_overrides": {
    "newtab": "src/newtab/index.html"
  }
}
